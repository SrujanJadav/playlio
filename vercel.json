{
  "cleanUrls": true,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://playlio.onrender.com/api/$1"
    },
    {
      "src": "/socket.io/(.*)",
      "dest": "https://playlio.onrender.com/socket.io/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
